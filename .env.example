DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/scrapeflow_context
APP_NAME=ScrapeFlow Scraper Service
ENV=development
REDIS_URL=redis://localhost:6379/0
OUTPUT_DIR=outputs
DEFAULT_HEADLESS=true
DEFAULT_TIMEOUT=30000
MAX_PAGES_DEFAULT=5
SLM_ENABLED=true
SLM_PROVIDER=gemini
SLM_MODEL=gemini-3.5-flash
SLM_API_URL=
SLM_API_KEY=
SLM_TIMEOUT=30
SLM_MAX_INPUT_CHARS=12000
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SESSION_SECRET=change-this-in-production
SESSION_COOKIE_NAME=scrapeflow_session
SESSION_MAX_AGE=604800
SESSION_HTTPS_ONLY=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RUN_STARTUP_MIGRATIONS=false
